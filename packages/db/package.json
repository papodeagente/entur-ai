{
  "name": "@entur-ai/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "migrate:compiled": "node dist/migrate.js",
    "build": "tsc -p tsconfig.json && cp -r drizzle dist/drizzle",
    "studio": "drizzle-kit studio",
    "push": "drizzle-kit push"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
